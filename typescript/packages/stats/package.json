{
  "name": "@codeserk/forge-stats",
  "version": "0.3.3",
  "description": "Stats client for Forge. Tracks events, errors, and page views with HMAC-signed requests.",
  "license": "MIT",
  "keywords": [
    "forge",
    "analytics",
    "stats",
    "tracking",
    "events",
    "error-tracking"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "readme": "README.md",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:dry": "npm publish --dry-run",
    "publish:npm": "npm run build && npm publish",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.21.4",
    "typescript": "^5.7.0"
  }
}
