{
  "name": "@codeserk/forge-stats-react-native",
  "version": "0.2.2",
  "description": "React Native wrapper for Forge Stats. Pure-JS HMAC signing, no native crypto modules needed.",
  "license": "MIT",
  "keywords": [
    "forge",
    "analytics",
    "stats",
    "tracking",
    "events",
    "error-tracking",
    "react-native"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:dry": "npm publish --dry-run",
    "publish:npm": "npm run build && npm publish"
  },
  "dependencies": {
    "@codeserk/forge-stats": "^0.3.0",
    "js-sha256": "^0.11.0"
  },
  "peerDependencies": {
    "react-native": ">=0.60.0"
  },
  "devDependencies": {
    "@types/react-native": "^0.72.8",
    "tsdown": "^0.21.4",
    "typescript": "^5.7.0"
  }
}
