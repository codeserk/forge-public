---
interface Props {
  href?: string
  variant?: 'default' | 'primary' | 'ghost'
  size?: 'small' | 'default' | 'large'
}

const { href, variant = 'default', size = 'default' } = Astro.props
---

{
  href ? (
    <a href={href} class={`btn variant-${variant} size-${size}`}>
      <slot />
    </a>
  ) : (
    <button class={`btn variant-${variant} size-${size}`}>
      <slot />
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;

    svg {
      fill: currentColor;
    }
    font-family: var(--font-body);
    letter-spacing: 0.05em;
    text-decoration: none;
    cursor: pointer;
    border: 4px solid transparent;

    /* sizes */
    &.size-small {
      height: var(--control-size-small);
      padding: 0 0.75rem;
      font-size: var(--font-sm);
    }

    &.size-default {
      height: var(--control-size-middle);
      padding: 0 1rem;
      font-size: var(--font-md);
    }

    &.size-large {
      height: var(--control-size-large);
      padding: 0 1.25rem;
      font-size: var(--font-lg);
    }

    /* variants */
    &.variant-default {
      background-color: var(--color-control);
      color: var(--color-text);
      border-color: var(--color-border);
      box-shadow: 0px 6px 0 var(--color-shadow);

      &:hover {
        transform: translate(0px, 2px);
        box-shadow: 0px 4px 0 var(--color-shadow);
      }

      &:focus {
        outline: none;
        transform: translate(0px, 4px);
        box-shadow: 0px 2px 0 var(--color-shadow);
      }
    }

    &.variant-primary {
      background-color: var(--color-primary);
      color: var(--color-black);
      border-color: var(--color-light);
      box-shadow: 0px 6px 0 var(--color-shadow);

      &:hover {
        background-color: var(--color-primary-light);
        transform: translate(0px, 2px);
        box-shadow: 0px 4px 0 var(--color-shadow);
      }

      &:focus {
        outline: none;
        transform: translate(0px, 4px);
        box-shadow: 0px 2px 0 var(--color-shadow);
      }
    }

    &.variant-ghost {
      background-color: transparent;
      color: var(--color-light);
      border: none;

      &:hover,
      &:focus {
        color: var(--color-primary);
      }
    }
  }
</style>
