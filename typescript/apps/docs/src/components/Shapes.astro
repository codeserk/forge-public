<div class="shapes">
  <div class="shape shape-1" style="top: 15%; left: 20%; animation-delay: 0.3s"></div>
  <div class="shape shape-1" style="top: 75%; left: 80%; animation-delay: 1.2s"></div>
  <div class="shape shape-2" style="top: 45%; left: 70%; animation-delay: 1.7s"></div>
  <div class="shape shape-2" style="top: 85%; left: 30%; animation-delay: 0.5s"></div>
  <div class="shape shape-3" style="top: 30%; left: 85%; animation-delay: 1.0s"></div>
  <div class="shape shape-3" style="top: 60%; left: 15%; animation-delay: 0.1s"></div>
</div>

<style>
  .shapes {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;

    .shape {
      position: fixed;
      z-index: -1;
      width: 8px;
      height: 8px;
      opacity: 0.2;
      animation: pixelDrift infinite;

      &.shape-1 {
        animation-duration: 30s;
        animation-timing-function: steps(15);
        box-shadow:
          150px 100px 0 var(--color-gray),
          158px 100px 0 var(--color-gray),
          150px 108px 0 var(--color-gray),
          158px 108px 0 var(--color-gray);
      }

      &.shape-2 {
        animation-duration: 20s;
        animation-timing-function: steps(10);
        box-shadow:
          -100px 100px 0 var(--color-green),
          -92px 100px 0 var(--color-green),
          -100px 108px 0 var(--color-green);
      }

      &.shape-3 {
        animation-duration: 10s;
        animation-timing-function: steps(5);
        box-shadow:
          8px 0 0 var(--color-bright),
          0 8px 0 var(--color-bright);
      }
    }
  }

  @keyframes pixelDrift {
    0% {
      transform: translateY(0) translateX(0);
      opacity: 0.2;
    }

    50% {
      transform: translateY(-20px) translateX(10px);
      opacity: 0.4;
    }

    100% {
      transform: translateY(0) translateX(0);
      opacity: 0.2;
    }
  }
</style>
