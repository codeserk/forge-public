---
import { PUBLIC_STATS_PREVIEW_URL } from 'astro:env/client'
---

{
  PUBLIC_STATS_PREVIEW_URL && (
    <section class="preview">
      <iframe src={PUBLIC_STATS_PREVIEW_URL} title="Stats preview" loading="lazy" />
    </section>
  )
}

<style>
  .preview {
    width: 100%;
    padding: 0 2rem;
    box-sizing: border-box;

    iframe {
      width: 100%;
      height: 600px;
      border: 4px solid var(--color-border);
      display: block;
    }
  }
</style>
