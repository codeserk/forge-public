---
import Icon from '../../Icon.astro'
import { PUBLIC_STATS_PREVIEW_URL } from 'astro:env/client'
---

{
  PUBLIC_STATS_PREVIEW_URL && (
    <div class="stats-preview">
      <h3>
        <Icon name="eye" size={28} /> Live Preview
      </h3>
      <div class="preview-frame">
        <iframe src={PUBLIC_STATS_PREVIEW_URL} title="Stats live preview" loading="lazy" />
      </div>
    </div>
  )
}

<style>
  .stats-preview {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;

    h3 {
      font-family: var(--font-heading-no-scale);
      font-size: var(--font-3xl);
      color: var(--color-text);
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
  }

  .preview-frame {
    position: relative;
    border: 4px solid var(--color-border);
    box-shadow: 0px 8px 0 var(--color-shadow);

    &::before,
    &::after {
      content: '';
      position: absolute;
      width: 10px;
      height: 10px;
      background: var(--color-border);
    }

    &::before {
      top: -2px;
      left: -2px;
    }

    &::after {
      bottom: -2px;
      right: -2px;
      box-shadow:
        -8px 0 0 var(--color-border),
        0 -8px 0 var(--color-border);
    }

    iframe {
      width: 100%;
      height: 640px;
      border: none;
      display: block;
    }
  }
</style>
