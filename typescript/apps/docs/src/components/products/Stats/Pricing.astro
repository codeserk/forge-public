---
import { ProductsStatsPricingView } from './Pricing'
---

<ProductsStatsPricingView client:load />

<style is:global>
  .stats-pricing {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;

    h3 {
      font-family: var(--font-heading-no-scale);
      font-size: var(--font-3xl);
      color: var(--color-text);
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
  }

  .pricing-controls {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .quota-slider {
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0 5rem;

    @media (max-width: 600px) {
      padding: 0;
    }

    .quota-label {
      display: flex;
      justify-content: space-between;
      font-size: var(--font-md);
      color: var(--color-text-subtle);

      strong {
        color: var(--color-primary);
        font-family: var(--font-heading);
        font-size: var(--font-xl);
      }
    }

    input[type='range'] {
      width: 100%;
      appearance: none;
      height: 6px;
      background: var(--color-border);
      outline: none;
      cursor: pointer;
      padding: 0 0px;
      box-sizing: border-box;

      &::-webkit-slider-thumb {
        appearance: none;
        width: 20px;
        height: 20px;
        border-radius: 0;
        background: var(--color-primary);
        cursor: pointer;
      }

      &::-moz-range-thumb {
        width: 20px;
        height: 20px;
        border-radius: 0;
        background: var(--color-primary);
        border: none;
        cursor: pointer;
      }
    }

    .quota-ticks {
      display: flex;
      justify-content: space-between;
      padding: 0 0px;

      .tick {
        font-size: var(--font-sm);
        color: var(--color-border);
        cursor: pointer;
        letter-spacing: 0.05em;
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        text-transform: uppercase;
        text-align: center;

        @media (max-width: 600px) {
          font-size: var(--font-xs);
          letter-spacing: 0;
        }

        &:first-child,
        &:nth-child(2) {
          text-align: left;
        }

        &:last-child,
        &:nth-last-child(2) {
          text-align: right;
        }

        &.tick-active {
          color: var(--color-primary);
        }
      }
    }
  }

  .billing-toggle {
    display: flex;
    align-items: center;
    gap: 1rem;

    .toggle-label {
      font-size: var(--font-md);
      color: var(--color-text-subtle);

      &.toggle-label-active {
        color: var(--color-text);
      }
    }
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .tiers-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .tiers-grid {
      grid-template-columns: 1fr;
    }
  }

  .tier-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 1rem;
    background-color: var(--color-container);
    position: relative;

    --card-color-border: var(--color-border);
    --card-color-shadow: var(--color-shadow);

    border: 4px solid var(--card-color-border);
    box-shadow: 0px 8px 0 var(--card-color-shadow);

    &::before,
    &::after {
      content: '';
      position: absolute;
      width: 10px;
      height: 10px;
      background: var(--card-color-border);
    }

    &::before {
      top: -2px;
      left: -2px;
    }

    &::after {
      bottom: -2px;
      right: -2px;
      box-shadow:
        -8px 0 0 var(--card-color-border),
        0 -8px 0 var(--card-color-border);
    }

    &.tier-disabled {
      opacity: 0.4;
    }

    .tier-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .tier-name {
      font-family: var(--font-heading);
      font-size: var(--font-2xl);
      color: var(--color-primary);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .tier-tag {
      font-size: var(--font-xs);
      color: var(--color-light);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tier-desc {
      font-size: var(--font-lg);
      color: var(--color-text-subtle);
      line-height: 1.6;
      margin: 0;
      min-height: 5em;
    }

    .tier-features {
      list-style: none;
      padding: 0;
      margin: 0;
      gap: 0.5rem 1rem;
      flex: 1;

      li {
        font-size: var(--font-md);
        color: var(--color-text-subtle);
        display: flex;
        align-items: center;
        gap: 0.25em;

        svg {
          fill: var(--color-primary);
          flex-shrink: 0;
        }
      }
    }

    .tier-price {
      display: flex;
      align-items: baseline;
      justify-content: center;
      gap: 0.25rem;
      padding-top: 0.5rem;
      min-height: 50px;

      .price-amount {
        font-family: var(--font-heading-no-scale);
        font-size: var(--font-5xl);
        color: var(--color-primary);
      }

      .price-period {
        font-size: var(--font-md);
        color: var(--color-text-subtle);
      }

      .price-na,
      .price-contact {
        font-size: var(--font-lg);
        color: var(--color-text-subtle);
      }
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    .tier-features li {
      font-size: var(--font-lg);
    }
  }

  @media (max-width: 1024px) {
    .tier-card .tier-desc {
      min-height: unset;
    }
    .tier-card .tier-features li {
      font-size: var(--font-lg);
    }
  }
</style>
