---
import Icon from '../../Icon.astro'

const features = [
  {
    icon: 'eye',
    name: 'Page views',
    desc: 'Automatic tracking for plain HTML, SPAs, and Astro - including View Transitions.',
    available: true,
  },
  {
    icon: 'users',
    name: 'Sessions',
    desc: 'Session tracking with bounce rate. No cookies - IPs are hashed and rotated.',
    available: true,
  },
  {
    icon: 'map',
    name: 'Geo-location',
    desc: 'Country and region data from incoming requests. No extra SDK needed.',
    available: true,
  },
  {
    icon: 'trending',
    name: 'Realtime',
    desc: 'Live view of what is happening on your site right now.',
    available: false,
  },
  {
    icon: 'bug',
    name: 'Error tracking',
    desc: 'Capture and group errors. Like Sentry, but without the invoice shock.',
    available: false,
  },
  {
    icon: 'speed-fast',
    name: 'Performance',
    desc: 'Lighthouse-style metrics split by device and OS.',
    available: false,
  },
  {
    icon: 'sliders',
    name: 'Custom queries',
    desc: 'Filter and aggregate your events however you need.',
    available: false,
  },
  {
    icon: 'cloud-download',
    name: 'Data export',
    desc: 'Email digests and S3 exports. Your data, your way.',
    available: false,
  },
]
---

<div class="features-section">
  <h3><Icon name="list" size={28} /> Features</h3>
  <div class="features-grid">
    {
      features.map(({ icon, name, desc, available }) => (
        <div class={`feature ${!available ? 'feature-disabled' : ''}`}>
          <div class="feature-header">
            <Icon name={icon} size={24} />
            <span class="feature-name">{name}</span>
          </div>
          <span class="feature-desc">{desc}</span>
          <span class="feature-tag">{available ? 'Available' : 'Coming soon'}</span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .features-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    h3 {
      font-family: var(--font-heading-no-scale);
      font-size: var(--font-3xl);
      color: var(--color-text);
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background-color: var(--color-container);
    position: relative;

    --card-color-border: var(--color-border);
    --card-color-shadow: var(--color-shadow);

    border: 4px solid var(--card-color-border);
    box-shadow: 0px 8px 0 var(--card-color-shadow);

    &::before,
    &::after {
      content: '';
      position: absolute;
      width: 10px;
      height: 10px;
      background: var(--card-color-border);
    }

    &::before {
      top: -2px;
      left: -2px;
    }

    &::after {
      bottom: -2px;
      right: -2px;
      box-shadow:
        -8px 0 0 var(--card-color-border),
        0 -8px 0 var(--card-color-border);
    }

    &.feature-disabled {
      opacity: 0.4;
    }

    .feature-header {
      display: flex;
      align-items: center;
      gap: 0.5rem;

      svg {
        fill: var(--color-primary);
      }
    }

    .feature-name {
      font-family: var(--font-heading);
      font-size: var(--font-lg);
      color: var(--color-primary);
    }

    .feature-desc {
      font-size: var(--font-md);
      color: var(--color-text-subtle);
      line-height: 1.6;
      flex: 1;
    }

    .feature-tag {
      font-size: var(--font-xs);
      color: var(--color-light);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  }
</style>
