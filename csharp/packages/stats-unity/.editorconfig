root = true

[*.cs]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# StyleCop rules
dotnet_diagnostic.SA0001.severity = none  # XML comment analysis (disabled - no doc generation)
dotnet_diagnostic.SA1200.severity = none  # Using directives placement (allow outside namespace)
dotnet_diagnostic.SA1633.severity = none  # File header
dotnet_diagnostic.SA1101.severity = none  # Prefix local calls with this
dotnet_diagnostic.SA1309.severity = none  # Field names must not begin with underscore (we use _field)
dotnet_diagnostic.SA1310.severity = none  # Field names must not contain underscore
dotnet_diagnostic.SX1309.severity = warning  # Field names must begin with underscore
dotnet_diagnostic.SA1401.severity = none  # Public fields allowed (Unity serialized fields)
dotnet_diagnostic.CS8618.severity = none  # Non-nullable field uninitialized (Unity sets serialized fields)

# Naming
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix
dotnet_naming_rule.private_fields_underscore.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case
